# ============================================================
# Post AI Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------------------------
# Anthropic (required)
# ----------------------------------------------------------
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# LinkedIn (required for publishing; not needed for --dry-run)
# ----------------------------------------------------------
# Generate an OAuth 2.0 access token with these scopes:
#   w_member_social   (to post as a person)
#   w_organization_social (to post as a company page)
#   r_liteprofile     (to auto-detect your URN)
#
# Quickstart: https://developer.linkedin.com/products/share-on-linkedin
LINKEDIN_ACCESS_TOKEN=AQV...

# Optional: your LinkedIn URN (auto-detected if left blank)
# Format:  urn:li:person:XXXXXXXX   (personal profile)
#          urn:li:organization:NNNN (company page)
LINKEDIN_AUTHOR_URN=
